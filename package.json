{
  "name": "codeisland-win",
  "version": "0.1.0",
  "description": "Real-time AI coding agent status island for Windows (Claude Code). A Windows port of CodeIsland.",
  "main": "src/main/main.js",
  "scripts": {
    "test": "node --test",
    "start": "electron .",
    "bridge": "node src/bridge/bridge.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win",
    "exe": "electron-builder --win portable"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.codeisland.win",
    "productName": "CodeIsland",
    "files": [
      "src/**/*",
      "!**/*.test.js"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "src/assets/claude.png"
    },
    "portable": {
      "artifactName": "CodeIsland.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
